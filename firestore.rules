rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // Admin invites (if used)
    match /admin-invites/{inviteId} {
      allow read, write: if isSignedIn();
    }

    // Gallery: public can read (view images)
    match /gallery/{imageId} {
      allow read: if true;
      allow write: if false;
    }

    // Buy Rice listings (products)
    match /buy-rice/{listingId} {
      allow read: if true;
      allow write: if false;
    }

    // Rice Orders (this fixes “missing or insufficient permissions” on checkout)
    match /riceOrders/{orderId} {
      // Users can read only their own orders
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;

      // Users can create orders only for themselves
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;

      // No client-side edits/deletes
      allow update, delete: if false;
    }

    // Investments
    match /investments/{investmentId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Cooperative Members
    match /cooperativeMembers/{memberId} {
        allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
        allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
        allow update, delete: if false;
    }

    // Trainings
    match /trainings/{trainingId} {
        allow read: if isSignedIn();
        allow create, update, delete: if false; // Or restrict to admin
    }

    // Payments
    match /payments/{paymentId} {
        allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
        allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
        allow update, delete: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
